# ==============================================
# E-Commerce Microservices Platform - Environment
# ==============================================

# Node
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-me
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MongoDB
MONGO_URI=mongodb://localhost:27017
AUTH_DB_NAME=auth_db
USER_DB_NAME=user_db
PRODUCT_DB_NAME=product_db
INVENTORY_DB_NAME=inventory_db
ORDER_DB_NAME=order_db
PAYMENT_DB_NAME=payment_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@ecommerce.com

# Services Ports
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
PRODUCT_SERVICE_PORT=8003
INVENTORY_SERVICE_PORT=8004
CART_SERVICE_PORT=8005
ORDER_SERVICE_PORT=8006
PAYMENT_SERVICE_PORT=8007
SEARCH_SERVICE_PORT=8008
NOTIFICATION_SERVICE_PORT=8009
RECOMMENDATION_SERVICE_PORT=8010

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=http://localhost:8009

# Cors
CORS_ORIGIN=http://localhost:3000
